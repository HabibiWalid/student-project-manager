# Copy to .env and fill in real values. NEVER commit .env.
# Placeholders only below — do not use these values in production.

# --- Core ---
# Session cookie signing key. MUST be >= 32 chars. Generate a random one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-a-random-string-of-at-least-32-characters

# SQLAlchemy database URL. Default is local SQLite.
DATABASE_URL=sqlite:///./app.db

# Set to true in production (served over HTTPS) so the session cookie is Secure.
SESSION_COOKIE_SECURE=false

# Optional: override the session cookie name.
# SESSION_COOKIE_NAME=spm_session

# Directory for uploaded submission files. Must NOT be a web-served/static path
# and should be on a non-executable volume. Created at startup if missing.
UPLOAD_DIR=./uploads

# --- Seed users (used only by `python -m seed`) ---
# Passwords are REQUIRED and have no defaults; seeding fails loudly if missing.
SEED_TEACHER_EMAIL=teacher@example.com
SEED_TEACHER_PASSWORD=replace-with-a-strong-password
SEED_TEACHER_NAME=王老师

SEED_STUDENT1_EMAIL=student1@example.com
SEED_STUDENT1_PASSWORD=replace-with-a-strong-password
SEED_STUDENT1_NAME=张三

SEED_STUDENT2_EMAIL=student2@example.com
SEED_STUDENT2_PASSWORD=replace-with-a-strong-password
SEED_STUDENT2_NAME=李四
